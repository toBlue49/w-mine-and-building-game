[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="player"
3d_physics/layer_3="world_border"
3d_physics/layer_4="item"
3d_physics/layer_5="entity"

[physics]

common/physics_ticks_per_second=80
3d/default_gravity=25.0

[rendering]

textures/vram_compression/import_etc2_astc=true
textures/vram_compression/compress_with_gpu=false
textures/vram_compression/cache_gpu_compressor=false
textures/lossless_compression/force_png=true
lights_and_shadows/directional_shadow/size=8192
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=0
lights_and_shadows/directional_shadow/soft_shadow_filter_quality.mobile=1
occlusion_culling/use_occlusion_culling=true
